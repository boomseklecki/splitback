# Copy to .env and fill in. Secrets stay server-side; the iOS app never sees these.
# This is the DEVELOPMENT stack (default services db-dev/minio/api-dev on :8001, PLAID_ENV=sandbox). For
# the production stack run side-by-side (`docker compose --profile prod`, :8000), copy .env.prod.example
# -> .env.prod.

# Core
APP_NAME=SplitBack
DEFAULT_CURRENCY=USD
# PUBLIC_HOSTNAME: friendly label shown on the iOS join/confirm screen (GET /server-info),
# e.g. "Matt's Household". Defaults to APP_NAME when blank.
PUBLIC_HOSTNAME=
# Bearer tokens for app endpoints: JSON map of token -> identifier. Empty = open (no auth); setting any
# makes the server require a token (the app shows its gate). Bypasses AUTH_ALLOWED_USERS (operator-trusted).
# DEV IMPERSONATION: map demo tokens to seeded users so a tester signs in AS that member (and sees their
# scoped data + balances). Hand out a token; the tester pastes it in the gate's "Have an access token?"
# field. Seed first: `python -m app.cli.seed_dev --as matt --wipe`. Example:
#   {"demo-matt":"matt","demo-robin":"robin","demo-sam":"sam"}
API_TOKENS={}
# Delete behavior. Groups/expenses archive (soft-delete) by default; set true to hard-delete.
# (expenses flag governs local-only expenses; Splitwise-linked ones follow group state / ?propagate=)
GROUPS_HARD_DELETE_ENABLED=false
EXPENSES_HARD_DELETE_ENABLED=false

# Real auth (Apple / Google / Splitwise sign-in -> backend-issued JWT). See README "Authentication".
# AUTH_JWT_SECRET: HS256 signing secret. Generate: openssl rand -hex 32
AUTH_JWT_SECRET=
# AUTH_REQUIRED: false keeps open mode (dev/tests). Set true to require a valid token on app endpoints.
AUTH_REQUIRED=false
# AUTH_ALLOWED_USERS: JSON list of emails permitted to sign in (empty = anyone verified). Enforced at
# sign-in AND every request. CLOSED_REGISTRATION=true blocks creating NEW users (existing only). Leave
# open in dev.
AUTH_ALLOWED_USERS=[]
CLOSED_REGISTRATION=false
# SCOPING_PRIMARY_OWNER: only read by the 0020 migration to backfill existing un-owned accounts/
# transactions/goals to this identifier. Per-caller scoping only filters when AUTH_REQUIRED makes a
# caller present, so dev (open) stays unscoped regardless.
SCOPING_PRIMARY_OWNER=
# GOOGLE_CLIENT_ID: the Google Cloud OAuth *iOS* client id (xxxx.apps.googleusercontent.com) — token aud.
GOOGLE_CLIENT_ID=
# APPLE_AUDIENCE: the iOS app bundle id (e.g. com.splitback.app) — the Apple identity-token aud.
APPLE_AUDIENCE=
# APPLE_TEAM_ID: Apple Developer Team ID — serves /.well-known/apple-app-site-association for
# Universal Links (appID = <APPLE_TEAM_ID>.<APPLE_AUDIENCE>). Universal Links 404 until this is set.
APPLE_TEAM_ID=

# Postgres — the dev DB service is "db-dev" (compose also pins this for api-dev/api-test/api-prod).
DATABASE_URL=postgresql+asyncpg://splitback:splitback@db-dev:5432/splitback

# MinIO (matches docker-compose service name "minio")
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=splitback
MINIO_SECRET_KEY=splitback-secret
MINIO_BUCKET=receipts
MINIO_SECURE=false
# MinIO is reached only by the api container over the in-cluster name above. Receipt bytes
# flow through the API (POST/GET /receipts...), so the iOS client never reaches MinIO directly
# and there is no public host to configure.

# Plaid. PLAID_ENV: sandbox | production (the secret differs per env; client_id is shared).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# PLAID_REDIRECT_URI: required for production OAuth banks. Register the EXACT value in the Plaid
# dashboard, ensure the app's AASA covers its path (/plaid/oauth*) + the iOS app handles the
# Universal Link, then set it here. Leave blank otherwise — an unregistered value rejects every
# link token. e.g. https://splitback.app/plaid/oauth
PLAID_REDIRECT_URI=

# Splitwise OAuth app (consumer key/secret act as OAuth2 client id/secret).
# SPLITWISE_REDIRECT_URI must match the callback registered in your Splitwise app (use the public
# https host in production, e.g. https://splitback.app/auth/splitwise/callback).
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=http://localhost:8000/auth/splitwise/callback
# Map Splitwise user ids to local identifiers, e.g. {"123":"matt","456":"nikki"}
SPLITWISE_USER_MAP={}

# Cloudflare Tunnel (public HTTPS exposure). Compose-only — the API never reads this.
# Create a remotely-managed tunnel in the Cloudflare dashboard, map a public hostname to
# http://api:8000, paste the connector token here, then:
#   docker compose --profile tunnel up -d cloudflared
# See README "Public access via Cloudflare Tunnel".
CLOUDFLARE_TUNNEL_TOKEN=
