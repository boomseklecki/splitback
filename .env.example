# The DEFAULT, real self-hosted instance config. Copy to `.env` and fill in, then `docker compose up -d`.
# This is the only stack a self-hoster needs (production Plaid). The optional sandbox uses `.env.dev`
# (`--profile dev`) and the demo uses `.env.demo` (`--profile demo`). All real `.env*` files are gitignored;
# secrets stay server-side and the iOS app never sees them.

# Core
APP_NAME=SplitBack
DEFAULT_CURRENCY=USD
# NOTE: server name, hard-delete toggles, sync/backup cadence + retention, and invite policy are ADMIN-
# EDITABLE IN-APP now (Settings -> Server Settings), stored in the DB — not env vars.
API_TOKENS={}

# Real auth. Generate a FRESH secret — do NOT reuse the dev one (so dev tokens can't authenticate here):
#   openssl rand -hex 32
AUTH_JWT_SECRET=
# Production should require auth.
AUTH_REQUIRED=true
# Enrollment is DB-backed: the first person to sign in claims the server (enrolled + admin); everyone after
# needs a single-use invite generated in-app (Settings -> Invite). No email allowlist to maintain here.
# Set to your /me identifier BEFORE `alembic upgrade head`: the 0020 migration backfills existing un-owned
# accounts/transactions/goals to this owner so per-caller scoping keeps them visible to you.
SCOPING_PRIMARY_OWNER=
# Admins (local identifiers) — see all people; reserved for gating settings. Set your /me identifier.
ADMIN_USERS=[]
# REQUIRED for production: Fernet keys encrypting Plaid/Splitwise access tokens at rest. Set BEFORE
# `alembic upgrade head` (the 0021 migration encrypts existing rows with it). The first key encrypts; keep
# old keys in the list to decrypt during rotation. Losing all keys means tokens must be re-linked (not data
# loss). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=[]
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# Postgres: docker-compose pins DATABASE_URL to the `db` service, so this is just a placeholder — leave as-is.
DATABASE_URL=postgresql+asyncpg://splitback:splitback@db:5432/splitback
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=splitback
MINIO_SECRET_KEY=splitback-secret
MINIO_BUCKET=receipts
BACKUPS_BUCKET=backups
MINIO_SECURE=false

# Docker volume that holds this instance's Postgres data. A fresh install can leave these defaults; an
# EXISTING operator binds their current (project-prefixed) volumes here so no data migrates — e.g.
# MAIN_DB_VOLUME=splitback_db_data_prod and DEV_DB_VOLUME=splitback_db_data (and set MINIO_BUCKET to the
# bucket your data already lives in, e.g. receipts-prod / BACKUPS_BUCKET=backups-prod).
MAIN_DB_VOLUME=db_data
DEV_DB_VOLUME=db_data_dev

# Plaid PRODUCTION. PLAID_ENV=production with the PRODUCTION secret (client_id is shared across envs).
# Production OAuth banks REQUIRE PLAID_REDIRECT_URI: register this EXACT value in the Plaid dashboard
# (production), confirm the app's AASA serves /plaid/oauth* (APPLE_TEAM_ID set) and the iOS app handles
# the Universal Link. An unregistered value rejects every link token.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_REDIRECT_URI=https://splitback.app/plaid/oauth

# Splitwise (production app). Use the public https callback registered in your Splitwise app.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=https://splitback.app/auth/splitwise/callback
SPLITWISE_USER_MAP={}

# Cloudflare Tunnel: point the public hostname at http://api:8000 in the dashboard, then run the connector
# with `--profile tunnel`. Compose-only (read via ${...} substitution from this auto-loaded .env) — the API
# never reads this.
CLOUDFLARE_TUNNEL_TOKEN=

# Push notifications go through the push relay (this server holds no Apple creds). Register your instance
# at https://push.splitback.app for an API key. PUSH_RELAY_URL is set in docker-compose (http://relay:8000)
# if you run the relay container; override here to point at a VPS. Empty key = push disabled.
PUSH_RELAY_API_KEY=
# PUSH_RELAY_URL=https://push.splitback.app
