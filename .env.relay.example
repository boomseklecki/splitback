# Push relay config. Copy to .env.relay. Holds the ONE official APNs key for the published app
# (com.splitback.app); self-hosted instances never see these — they POST to the relay with an issued
# API key. Leave empty to run the relay in a disabled state (/push returns 503).

# APNs token-based auth (.p8 from the Apple Developer account).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.splitback.app
APNS_AUTH_KEY=          # base64 of the .p8 PEM: `base64 -i AuthKey_XXXX.p8`
APNS_ENV=production     # "production" or "sandbox" (dev/TestFlight)

# Operations
ADMIN_TOKEN=            # gates /admin/keys/{id}/approve|revoke (a long random string); empty = admin off
RELAY_AUTO_ISSUE=true   # register → key immediately; false = pending until you approve
DB_PATH=/data/relay.db  # sqlite store (mount a volume at /data)
# Refuse plaintext-body pushes and forward only E2E-encrypted (opaque) payloads. Leave false for a solo
# instance; set true before opening the relay to other self-hosters so it can't see their content.
RELAY_REQUIRE_E2EE=false

# Abuse limits
REGISTER_MAX_PER_HOUR=5   # per IP
PUSH_MAX_PER_MINUTE=600   # per key
