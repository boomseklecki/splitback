# PRODUCTION stack template. Copy to .env.prod and fill in. Used by the `api-prod` service
# (docker compose --profile prod). Keep this DISTINCT from .env (the development stack): a separate
# JWT secret, production Plaid credentials, and the production Splitwise app + redirect. Both .env and
# .env.prod are gitignored. Secrets stay server-side; the iOS app never sees these.

# Core
APP_NAME=SplitBack
DEFAULT_CURRENCY=USD
# Shown on the iOS join/confirm screen. Make it obviously the real one (e.g. "Matt's Household").
PUBLIC_HOSTNAME=
API_TOKENS={}
GROUPS_HARD_DELETE_ENABLED=false
EXPENSES_HARD_DELETE_ENABLED=false

# Real auth. Generate a FRESH secret — do NOT reuse the dev one (so dev tokens can't authenticate here):
#   openssl rand -hex 32
AUTH_JWT_SECRET=
# Production should require auth.
AUTH_REQUIRED=true
# Only these emails may sign in (enforced at sign-in + every request). Set BEFORE exposing prod publicly.
AUTH_ALLOWED_USERS=["you@example.com"]
# Once everyone's imported, set true so no new identities can self-register (existing users still sign in).
CLOSED_REGISTRATION=false
# Set to your /me identifier BEFORE `alembic upgrade head`: the 0020 migration backfills existing un-owned
# accounts/transactions/goals to this owner so per-caller scoping keeps them visible to you.
SCOPING_PRIMARY_OWNER=
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# Postgres + MinIO bucket are pinned by docker-compose (db-prod / receipts-prod); these are placeholders
# the compose `environment:` overrides. Leave as-is.
DATABASE_URL=postgresql+asyncpg://splitback:splitback@db-prod:5432/splitback
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=splitback
MINIO_SECRET_KEY=splitback-secret
MINIO_BUCKET=receipts-prod
MINIO_SECURE=false

# Plaid PRODUCTION. PLAID_ENV=production with the PRODUCTION secret (client_id is shared across envs).
# Production OAuth banks REQUIRE PLAID_REDIRECT_URI: register this EXACT value in the Plaid dashboard
# (production), confirm the app's AASA serves /plaid/oauth* (APPLE_TEAM_ID set) and the iOS app handles
# the Universal Link. An unregistered value rejects every link token.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_REDIRECT_URI=https://splitback.app/plaid/oauth

# Splitwise (production app). Use the public https callback registered in your Splitwise app.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=https://splitback.app/auth/splitwise/callback
SPLITWISE_USER_MAP={}

# Cloudflare Tunnel: point the public hostname at http://api-prod:8000 in the dashboard, then run the
# connector with `--profile tunnel`. Compose-only — the API never reads this.
CLOUDFLARE_TUNNEL_TOKEN=
