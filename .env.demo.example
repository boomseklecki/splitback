# DEMO stack template. Copy to .env.demo and fill in. Used by the `api-demo` service
# (docker compose --profile demo). This is a PUBLIC, DISPOSABLE backend for TestFlight testers: guest login
# (DEMO_MODE) auto-seeds each tester an isolated sample app, Plaid is SANDBOX only, and there are no
# Splitwise creds so "Connect Splitwise" stays unavailable. Keep DISTINCT from .env / .env.prod: its own
# JWT secret and Postgres volume. .env.demo is gitignored. Secrets stay server-side; the iOS app never sees these.

# Core
APP_NAME=SplitBack
DEFAULT_CURRENCY=USD
# Shown on the iOS join/confirm screen. Make it obviously the demo (e.g. "SplitBack Demo").
PUBLIC_HOSTNAME=SplitBack Demo
API_TOKENS={}
GROUPS_HARD_DELETE_ENABLED=false
EXPENSES_HARD_DELETE_ENABLED=false

# Guest login. Enables POST /auth/demo (name-only, no OAuth) which mints an ephemeral demo-* user and
# auto-seeds it an isolated sample app. 404 on prod/dev (where this is false).
DEMO_MODE=true

# Real auth. Generate a FRESH secret — do NOT reuse the dev/prod one (so their tokens can't authenticate
# here, and vice versa):  openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_REQUIRED=true
# Empty allowlist: nobody may sign in via Apple/Google here. Guests come in ONLY through /auth/demo, which
# bypasses the allowlist by design (ephemeral demo-* identities).
AUTH_ALLOWED_USERS=[]
# Anyone can start a demo, so leave registration open.
CLOSED_REGISTRATION=false
# Fresh DB — no legacy un-owned rows to backfill. Leave blank.
SCOPING_PRIMARY_OWNER=
# No admins on the public demo.
ADMIN_USERS=[]
# Optional on demo (only sandbox tokens are stored). Leave empty to store them as plaintext, or set a Fernet
# key to exercise encryption. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=[]
# Demo testers use guest login, but leave these set if you also want Apple/Google to work (they won't pass
# the empty allowlist above unless you add emails).
GOOGLE_CLIENT_ID=
APPLE_AUDIENCE=
APPLE_TEAM_ID=

# Postgres + MinIO bucket are pinned by docker-compose (db-demo / receipts-demo); these are placeholders
# the compose `environment:` overrides. Leave as-is.
DATABASE_URL=postgresql+asyncpg://splitback:splitback@db-demo:5432/splitback
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=splitback
MINIO_SECRET_KEY=splitback-secret
MINIO_BUCKET=receipts-demo
MINIO_SECURE=false

# Plaid SANDBOX. PLAID_ENV=sandbox with the SANDBOX secret (client_id is shared across envs). Sandbox banks
# don't require a redirect, but registering this lets OAuth-style sandbox flows work end-to-end; confirm the
# app's AASA serves /plaid/oauth* (APPLE_TEAM_ID set) if you exercise that path.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=https://demo.splitback.app/plaid/oauth

# No Splitwise on the demo: leave these blank so "Connect Splitwise" is unavailable.
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_REDIRECT_URI=
SPLITWISE_USER_MAP={}

# Cloudflare Tunnel: point demo.splitback.app at http://api-demo:8000 in the dashboard, then run the
# connector with `--profile tunnel`. Compose-only — the API never reads this.
CLOUDFLARE_TUNNEL_TOKEN=
